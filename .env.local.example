# ============================================================
# Active Directory / LDAP Configuration
# ============================================================

# Primary DC IP (will failover to the others automatically)
AD_HOST=10.100.10.20

# All available DCs — comma-separated (failover list)
AD_HOSTS=10.100.10.20,10.100.10.6,10.100.10.7,10.100.10.21,10.100.10.3

# LDAP port — 389 for plain LDAP, 636 for LDAPS (SSL)
AD_PORT=636

# Timeouts in milliseconds (optional)
# AD_CONNECT_TIMEOUT=8000
# AD_TIMEOUT=20000

# Use SSL? true | false  (set true if using port 636)
AD_USE_SSL=true

# Your Active Directory domain  e.g. company.local
AD_DOMAIN=zewailcity.local

# Optional NetBIOS name for DOMAIN\user bind (e.g. ZEWAILCITY) if UPN bind fails
# AD_NETBIOS=ZEWAILCITY

# Base DN — e.g.  DC=company,DC=local
AD_BASE_DN=DC=zewailcity,DC=local

# Password changes use the user's own LDAPS bind (username + current password).
# No service account is required for change-password.

# Service account for admin password reset (needs "Reset Password" rights in AD)
AD_SERVICE_USER=aadam
AD_SERVICE_PASSWORD=Mos3addev@1281

# ============================================================
# Email / SMTP (required for reset-password)
# ============================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=learningtechnoltlogies@zewailcity.edu.eg
SMTP_PASSWORD=LTS_DEV_22_DAAE
SMTP_FROM=learningtechnologies@zewailcity.edu.eg

# ============================================================
# App Settings
# ============================================================

# Optional: Rate-limit (requests per minute per IP)
RATE_LIMIT_RPM=5

# Rate-limit for reset-password requests per IP
RESET_RATE_LIMIT_RPM=5

# Minimum hours between password changes (shown in policy error messages)
AD_MIN_PASSWORD_AGE_HOURS=24

# Reset-password tokens come from the portal as JWTs (payload + exp).
# No JWT secret or public key is required on this service.
